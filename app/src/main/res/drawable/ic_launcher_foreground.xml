<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Gemini-like 3D Star -->
    <path
        android:pathData="M54,20 C54,42 72,54 94,54 C72,54 54,66 54,88 C54,66 36,54 14,54 C36,54 54,42 54,20 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="14"
                android:startY="20"
                android:endX="94"
                android:endY="88"
                android:type="linear">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#A9C7FA" android:offset="0.3" />
                <item android:color="#E2A2E8" android:offset="0.7" />
                <item android:color="#F4B892" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner fold/shadow for 3D effect -->
    <path
        android:pathData="M54,20 C54,42 72,54 94,54 C72,54 54,54 54,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="20"
                android:endX="94"
                android:endY="54"
                android:type="linear">
                <item android:color="#CCFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Another fold -->
    <path
        android:pathData="M54,88 C54,66 36,54 14,54 C36,54 54,54 54,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="14"
                android:startY="54"
                android:endX="54"
                android:endY="88"
                android:type="linear">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#66110033" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Smaller star -->
    <path
        android:pathData="M80,18 C80,26 86,30 94,30 C86,30 80,34 80,42 C80,34 74,30 66,30 C74,30 80,26 80,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="66"
                android:startY="18"
                android:endX="94"
                android:endY="42"
                android:type="linear">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#A9C7FA" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
